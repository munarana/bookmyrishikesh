{
  "name": "yogarishikesh-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate -w @repo/database",
    "db:push": "npm run db:push -w @repo/database",
    "db:seed": "npm run db:seed -w @repo/database"
  }
}
